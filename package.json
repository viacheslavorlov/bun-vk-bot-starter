{
  "name": "bun-vk-bot-starter",
  "version": "1.0.0",
  "private": true,
  "description": "vk bot starter",
  "author": "vi-dev",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start": "bun run ./dist/index.js",
    "start:binary": "./bot",
    "start:node": "NODE_ENV=production node dist/index.js",
    "dev": "bun --watch ./src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun",
    "build:binary": "bun build --compile --minify --sourcemap ./src/index.ts --outfile bot",
    "build:bun": "bun build src/index.ts --outdir dist --target=bun --minify --sourcemap",
    "build:node": "bun build src/index.ts --outdir dist --target=node --minify --sourcemap",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "vk-io": "^4.10.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "standard-version": "^9.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
